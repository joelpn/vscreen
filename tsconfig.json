{
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"target": "esnext",
		"rootDir": "./src",
		"outDir": "./dist",
		"types": [
			"node"
		],
		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,
		"strict": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"moduleDetection": "force",
		"skipLibCheck": true
	},
	"include": [
		"src/**/*"
	],
	"exclude": [
		"node_modules",
		"dist"
	]
}